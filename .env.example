# App
APP_PORT=8080
BASE_URL=http://localhost:8080
LANGUAGE=english
DEBUG_MODE=TRUE
FRONTEND_URL=

# Database
DB_HOST=mysql
DB_NAME=easyappointments
DB_USERNAME=user
DB_PASSWORD=password

# MySQL
MYSQL_PORT=3306

# SMTP (mailpit)
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_AUTH=0
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_ADDRESS=info@example.org
SMTP_FROM_NAME=EasyAppointments
SMTP_REPLY_TO_ADDRESS=info@example.org
SMTP_PROTOCOL=tls
SMTP_TLS=NO

# Other services (not started by default)
NGINX_PORT=80
PHPMYADMIN_PORT=8081
MAILPIT_HTTP_PORT=8025
MAILPIT_SMTP_PORT=1025
SWAGGER_UI_PORT=8000
BAIKAL_PORT=8100
OPENLDAP_PORT=389
OPENLDAP_SSL_PORT=636
PHPLDAPADMIN_PORT=8200
